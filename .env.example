# Variáveis de Ambiente — Divisor de PDFs
# Copie este arquivo para .env e ajuste os valores

SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (produção) — usado apenas por config.settings.production
DB_NAME=divisor_pdf
DB_USER=divisor_pdf
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Upload limits
MAX_UPLOAD_SIZE_MB=500
MAX_TOTAL_UPLOAD_MB=2048

# Ghostscript
GHOSTSCRIPT_TIMEOUT_SECONDS=300

# Session / cleanup
SESSION_EXPIRY_SECONDS=3600
CLEANUP_INTERVAL_MINUTES=15
